  "grades": {
    "갑과": {
      "en": "First Class",
      "gloss": "The top three passers, headed by the valedictorian, who took the highest starting ranks."
    },
    "을과": {
      "en": "Second Class",
      "gloss": "The next seven passers in the standard triennial sitting."
    },
    "병과": {
      "en": "Third Class",
      "gloss": "The remaining twenty-three passers, the bulk of each class."
    },
    "정과": {
      "en": "Fourth Class",
      "gloss": "A lower pass grade carried over from the Goryeo system, recorded in some early rosters."
    },
    "동진사": {
      "en": "Associate Graduate",
      "gloss": "The lowest Goryeo-era grade, ranked below the third class and noted in some early rosters."
    },
