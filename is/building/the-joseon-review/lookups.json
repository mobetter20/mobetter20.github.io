  "seonggwan": {
    "이 전주": "The royal house of Joseon. The Jeonju Yi were the reigning dynasty, descended from the founder Yi Seong-gye, and the seat appears more often than any other in the rosters.",
    "권 안동": "A leading yangban lineage of the Andong Kwon. The clan name was granted by the founder of Goryeo, and the family supplied officials throughout the dynasty.",
    "윤 파평": "The Papyeong Yun. Among the most productive clans of royal consorts, having supplied several Joseon queens.",
    "홍 남양": "A prominent yangban lineage of the Namyang Hong, long represented among the central officials.",
    "김 안동": "The dominant in-law clan of the nineteenth-century sedo politics, when a few consort families controlled the court under the boy-kings Sunjo, Heonjong, and Cheoljong.",
    "한 청주": "The Cheongju Han. Noted for supplying royal consorts, with six queens drawn from the clan over the dynasty.",
    "박 밀양": "The Miryang Park, the principal Park lineage and one of the largest clans in Korea by descent.",
    "김 광산": "The Gwangsan Kim, a premier Neo-Confucian house. It produced the scholar Kim Jang-saeng and two sages enshrined at the Confucian shrine.",
    "이 연안": "The Yeonan Yi, an aristocratic clan well represented among the highest civil offices of the dynasty.",
    "민 여흥": "The Yeoheung Min. The clan of Queen Min, later titled Empress Myeongseong, and the source of earlier consorts including Sukjong's Queen Inhyeon.",
    "강 진주": "A prominent yangban lineage seated at Jinju, well represented among the officials of the dynasty.",
    "김 경주": "The Gyeongju Kim, descended from the royal house of Silla and seated at the old Silla capital.",
    "이 한산": "The Hansan Yi, the clan of Yi Saek, the late-Goryeo Neo-Confucian scholar known by the name Mogeun.",
    "박 반남": "The Bannam Park, a leading yangban house that supplied senior officials and royal in-laws in the later dynasty.",
    "정 동래": "The Dongnae Jeong, one of the most successful official-producing clans, with many chief state councillors.",
    "심 청송": "The Cheongsong Sim, a leading consort clan that supplied queens including Sejong's Queen Soheon.",
    "이 광주": "A prominent yangban lineage of the Gwangju Yi, well represented in the early and middle dynasty.",
    "이 전의": "A prominent yangban lineage seated at Jeonui, long present among the central officials.",
    "조 풍양": "The Pungyang Jo, the rival consort clan to the Andong Kim during the sedo politics of the early nineteenth century.",
    "신 평산": "The Pyeongsan Sin, founded by the Goryeo general Sin Sung-gyeom, who was granted the seat for service to the dynasty's founder."
  },
