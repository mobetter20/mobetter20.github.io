  "exams": {
    "식년시": {
      "en": "Triennial examination",
      "gloss": "The regular sitting held every three years, the meritocratic core of the system, seating thirty-three nationally."
    },
    "증광시": {
      "en": "Augmented examination",
      "gloss": "An extra sitting called to mark a national celebration such as a royal accession."
    },
    "별시": {
      "en": "Special examination",
      "gloss": "An irregular sitting called as the state required, outside the triennial cycle."
    },
    "정시": {
      "en": "Court-yard examination",
      "gloss": "A special sitting held in the palace court yard on a designated occasion."
    },
    "알성시": {
      "en": "Shrine-visit examination",
      "gloss": "Held when the king visited the Confucian shrine at the royal academy."
    },
    "중시": {
      "en": "Re-examination",
      "gloss": "A higher sitting open to officials already in service, used to mark them for advancement."
    },
    "외방별시": {
      "en": "Provincial special examination",
      "gloss": "A special sitting held in a province rather than the capital, often as a regional favour."
    },
    "춘당대시": {
      "en": "Chundangdae examination",
      "gloss": "A special sitting held at the Chundangdae terrace in the palace garden."
    },
    "친시": {
      "en": "Royally-presided examination",
      "gloss": "A sitting the king attended and judged in person."
    },
    "기로과": {
      "en": "Elders' examination",
      "gloss": "A special sitting reserved for elderly candidates and officials."
    },
    "발영시": {
      "en": "Balyeong examination",
      "gloss": "A one-off special sitting held under King Sejo in 1466 to draw out talent already in office."
    },
    "현량과": {
      "en": "Recommendation examination",
      "gloss": "A recommendation-based sitting introduced by the reformer Jo Gwangjo, selecting by reputation rather than written test."
    },
    "등준시": {
      "en": "Deungjun examination",
      "gloss": "An occasional special sitting for serving officials, held to identify men of distinction."
    },
    "탁영시": {
      "en": "Takyeong examination",
      "gloss": "A rare special sitting held to mark a particular court occasion."
    },
    "개시": {
      "en": "Capital district examination",
      "gloss": "A special sitting held for the capital and its surrounding districts."
    },
    "충량과": {
      "en": "Loyal-subject examination",
      "gloss": "A special sitting honouring the descendants of officials remembered for loyalty."
    },
    "탕평정시": {
      "en": "Tangpyeong court-yard examination",
      "gloss": "A court-yard sitting tied to the tangpyeong policy of balancing the political factions."
    },
    "구현과": {
      "en": "Talent-seeking examination",
      "gloss": "A special sitting named for its purpose of seeking out worthy men."
    },
    "식희과": {
      "en": "Sikhui examination",
      "gloss": "A rare special sitting held on a designated court occasion."
    },
    "진현시": {
      "en": "Worthy-presenting examination",
      "gloss": "A rare special sitting named for presenting able candidates to the throne."
    }
  },
